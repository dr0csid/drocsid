#================================================================
# Drocsid - environment configuration example
# Copy this file to .env and replace the placeholder values.
# ===================================================================

# -------------------------------------------------------------------
# Application
# -------------------------------------------------------------------
NODE_ENV=production
PORT=3002
APP_URL=""
VITE_BACKEND_URL=""
VITE_SUPERADMIN_EMAIL="admin@example.com"

# Additional allowed origins/hosts if needed
# Examples:
# CORS_EXTRA_ORIGINS="http://localhost:5173,https://app.example.com"
# ALLOWED_HOSTS_EXTRA="127.0.0.1:3002,example.com"
CORS_EXTRA_ORIGINS=""
ALLOWED_HOSTS_EXTRA=""

# -------------------------------------------------------------------
# Supabase
# -------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------------------
# LiveKit
# -------------------------------------------------------------------
VITE_LIVEKIT_URL=
VITE_LIVEKIT_TOKEN_ENDPOINT=/api/livekit/token
